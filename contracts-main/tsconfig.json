{
  "compilerOptions": {
    "target": "es2020",
    "module": "Node16",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "outDir": "dist",
  },
  "ts-node": {
    "esm": true,
    "experimentalSpecifierResolution": "node"
  },
  "include": ["./scripts", "./test"],
  "files": ["./hardhat.config.ts"],
  "exclude": ["node_modules"]
}
